{
  "name": "@neonloops/sdk",
  "version": "0.5.1",
  "description": "TypeScript SDK for Neonloops — run workflows via API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose"
  },
  "keywords": [
    "neonloops",
    "agent",
    "workflow",
    "sdk",
    "ai"
  ],
  "author": "Neonloops",
  "license": "MIT",
  "homepage": "https://neonloops.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/neonloops/sdk-node"
  },
  "bugs": {
    "url": "https://github.com/neonloops/sdk-node/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
